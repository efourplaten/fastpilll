    "android": {
      "package": "com.efourplaten.mobil",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "extra": {
      "eas": {
        "projectId": "8812754d-6901-4f23-965e-3dcb579f9136"
      }
    }
